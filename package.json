{
  "name": "@bitwarden/ai-plugins",
  "version": "0.0.0",
  "description": "Bitwarden AI Plugins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitwarden/ai-plugins.git"
  },
  "author": "Bitwarden Inc. <hello@bitwarden.com> (https://bitwarden.com)",
  "license": "SEE LICENSE IN LICENSE.txt",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "bugs": {
    "url": "https://github.com/bitwarden/ai-plugins/issues"
  },
  "homepage": "https://bitwarden.com",
  "devDependencies": {
    "cspell": "10.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3"
  },
  "lint-staged": {
    "*": "prettier --cache --write --ignore-unknown"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm run lint:prettier && pnpm run lint:spelling",
    "lint:prettier": "prettier --check .",
    "lint:spelling": "cspell lint --no-progress --no-summary --gitignore '**'",
    "format": "prettier --write ."
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "error"
    }
  }
}
