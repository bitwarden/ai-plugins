// app.js — render, navigation, decisions, comments, theme, export.
// Reads window.DIFFS and window.REVIEW_DATA.
// Keys are PR numbers (strings) rather than commit SHAs.
(function(){
  'use strict';

  const DIFFS_B64 = window.DIFFS || {};
  const PAGES_DATA = window.REVIEW_DATA || {};
  const PAGE_ORDER = window.PAGE_ORDER || [];

  // Map prKey → array of scene page numbers (1-based) for this stack.
  // Used to know the first/last scene page of each PR (decisions, intros).
  const SCENE_PAGES_BY_PR = {};
  PAGE_ORDER.forEach((p, i) => {
    if (p.kind !== "scene") return;
    (SCENE_PAGES_BY_PR[p.prKey] = SCENE_PAGES_BY_PR[p.prKey] || []).push(i + 1);
  });
  function firstScenePageOf(prKey) {
    const arr = SCENE_PAGES_BY_PR[prKey] || [];
    return arr[0];
  }
  function lastScenePageOf(prKey) {
    const arr = SCENE_PAGES_BY_PR[prKey] || [];
    return arr[arr.length - 1];
  }
  // First page index of a (prKey, chapterIndex) pair — used to know if the
  // current page is the FIRST scene of its chapter (chapter intro renders there).
  function firstPageOfChapter(prKey, chapterIndex) {
    for (let i = 0; i < PAGE_ORDER.length; i++) {
      const p = PAGE_ORDER[i];
      if (p.kind === "scene" && p.prKey === prKey && p.chapterIndex === chapterIndex) {
        return i + 1;
      }
    }
    return -1;
  }


// page numbering: 1 = cover, 2..N+1 = PAGES_DATA in stack order, N+2 = merge plan.
// __BW_BLOCK_START__ stack-config
const STACK_ORDER = __BW_STACK_ORDER__;
const TOTAL_PAGES = __BW_TOTAL_PAGES__;
const STORAGE_PREFIX = "__BW_STORAGE_PREFIX__";
// __BW_BLOCK_END__ stack-config

// ===== utils =====
function $(sel, root) { return (root || document).querySelector(sel); }
function $$(sel, root) { return Array.from((root || document).querySelectorAll(sel)); }
function el(tag, attrs, ...children) {
  const e = document.createElement(tag);
  if (attrs) for (const k in attrs) {
    if (k === "class") e.className = attrs[k];
    else if (k === "html") e.innerHTML = attrs[k];
    else if (k.startsWith("on")) e.addEventListener(k.slice(2), attrs[k]);
    else if (k === "dataset") Object.assign(e.dataset, attrs[k]);
    else if (attrs[k] === false || attrs[k] == null) {}
    else e.setAttribute(k, attrs[k]);
  }
  for (const c of children) {
    if (c == null || c === false) continue;
    if (typeof c === "string") e.appendChild(document.createTextNode(c));
    else if (Array.isArray(c)) c.forEach(cc => cc && e.appendChild(typeof cc === "string" ? document.createTextNode(cc) : cc));
    else e.appendChild(c);
  }
  return e;
}
function decodeB64(b) {
  const bin = atob(b);
  const bytes = new Uint8Array(bin.length);
  for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
  return new TextDecoder("utf-8").decode(bytes);
}
function escapeHtml(s) {
  return s.replace(/[&<>"']/g, c => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" })[c]);
}
function jiraUrl(ticket) { return `https://bitwarden.atlassian.net/browse/${ticket}`; }
function ghPrUrl(pr) { return `https://github.com/__BW_GH_REPO__/pull/${pr}`; }
function estimateMinutes(linesChanged, newFiles) {
  return Math.max(1, Math.round((linesChanged / 50) + (newFiles * 0.5)));
}

// ===== diff parsing =====
function parseUnifiedDiff(rawText) {
  // returns array of { path, header (lines), hunks: [{oldStart, newStart, lines: [{type, text, oldLn, newLn}]}] }
  const files = [];
  const lines = rawText.split("\n");
  let i = 0;
  // skip past any commit/Author/Date/message before first 'diff --git'
  while (i < lines.length && !lines[i].startsWith("diff --git")) i++;
  while (i < lines.length) {
    if (!lines[i].startsWith("diff --git")) { i++; continue; }
    const fileHeader = [];
    fileHeader.push(lines[i]); i++;
    let path = null;
    // header lines until first hunk
    while (i < lines.length && !lines[i].startsWith("@@") && !lines[i].startsWith("diff --git")) {
      fileHeader.push(lines[i]);
      if (lines[i].startsWith("+++ b/")) path = lines[i].slice(6);
      else if (lines[i].startsWith("+++ ") && !path) path = lines[i].slice(4);
      else if (lines[i].startsWith("rename to ") && !path) path = lines[i].slice("rename to ".length);
      i++;
    }
    const hunks = [];
    while (i < lines.length && lines[i].startsWith("@@")) {
      const hunkHead = lines[i];
      const m = /^@@ -(\d+)(?:,(\d+))? \+(\d+)(?:,(\d+))? @@/.exec(hunkHead);
      let oldLn = m ? parseInt(m[1], 10) : 0;
      let newLn = m ? parseInt(m[3], 10) : 0;
      const hunk = { head: hunkHead, lines: [] };
      i++;
      while (i < lines.length && !lines[i].startsWith("@@") && !lines[i].startsWith("diff --git")) {
        const l = lines[i];
        if (l.startsWith("+")) {
          hunk.lines.push({ type: "add", text: l.slice(1), oldLn: null, newLn: newLn++ });
        } else if (l.startsWith("-")) {
          hunk.lines.push({ type: "del", text: l.slice(1), oldLn: oldLn++, newLn: null });
        } else if (l.startsWith(" ")) {
          hunk.lines.push({ type: "ctx", text: l.slice(1), oldLn: oldLn++, newLn: newLn++ });
        } else if (l.startsWith("\\")) {
          // \ No newline at end of file
          hunk.lines.push({ type: "meta", text: l, oldLn: null, newLn: null });
        }
        i++;
      }
      hunks.push(hunk);
    }
    files.push({ path, header: fileHeader, hunks });
  }
  return files;
}

function detectLanguage(path) {
  if (!path) return "clike";
  if (path.endsWith(".swift")) return "swift";
  if (path.endsWith(".json")) return "json";
  if (path.endsWith(".strings")) return "clike";
  if (path.endsWith(".xml") || path.endsWith(".plist")) return "markup";
  return "clike";
}

function highlightLine(text, lang) {
  try {
    if (window.Prism && Prism.languages[lang]) {
      return Prism.highlight(text, Prism.languages[lang], lang);
    }
  } catch (e) {}
  return escapeHtml(text);
}

function renderFileDiff(file, prKey, annotations) {
  const lang = detectLanguage(file.path);
  const view = el("div", { class: "diff-view" });

  // File-level annotations render as a prologue above the first hunk.
  if (annotations && annotations.fileLevel && annotations.fileLevel.length) {
    const fileNotes = el("div", { class: "diff-file-notes" });
    annotations.fileLevel.forEach(a => fileNotes.appendChild(renderGloss(a)));
    view.appendChild(fileNotes);
  }
  const byLine = (annotations && annotations.byLine) || {};
  // header meta lines (index, ---/+++ etc) collapsed to a single small row
  const metaSummary = file.header.filter(h => h.startsWith("index ") || h.startsWith("rename ") || h.startsWith("similarity ")).join(" · ");
  if (metaSummary) {
    const r = el("div", { class: "diff-row meta" });
    r.appendChild(el("div", { class: "diff-ln" }));
    r.appendChild(el("div", { class: "diff-rn" }));
    r.appendChild(el("div", { class: "diff-marker" }));
    r.appendChild(el("div", { class: "diff-content", html: escapeHtml(metaSummary) }));
    r.appendChild(el("div", { class: "diff-action" }));
    view.appendChild(r);
  }
  for (const hunk of file.hunks) {
    const hr = el("div", { class: "diff-row hunk" });
    hr.appendChild(el("div", { class: "diff-ln" }));
    hr.appendChild(el("div", { class: "diff-rn" }));
    hr.appendChild(el("div", { class: "diff-marker" }));
    hr.appendChild(el("div", { class: "diff-content", html: escapeHtml(hunk.head) }));
    hr.appendChild(el("div", { class: "diff-action" }));
    view.appendChild(hr);
    for (const ln of hunk.lines) {
      const row = el("div", { class: "diff-row " + ln.type });
      row.dataset.sha = prKey;
      row.dataset.path = file.path || "";
      row.dataset.lineKey = `${ln.oldLn || ""}_${ln.newLn || ""}`;
      row.appendChild(el("div", { class: "diff-ln" }, ln.oldLn != null ? String(ln.oldLn) : ""));
      row.appendChild(el("div", { class: "diff-rn" }, ln.newLn != null ? String(ln.newLn) : ""));
      const marker = ln.type === "add" ? "+" : ln.type === "del" ? "−" : " ";
      row.appendChild(el("div", { class: "diff-marker" }, marker));
      const code = el("div", { class: "diff-content", html: highlightLine(ln.text, lang) });
      row.appendChild(code);
      // action button
      const action = el("div", { class: "diff-action" });
      if (ln.type !== "meta") {
        const btn = el("button", { type: "button", "aria-label": "Add inline comment", title: "Comment on line" }, "+");
        btn.addEventListener("click", (ev) => {
          ev.stopPropagation();
          openInlineCommentEditor(row, prKey, file.path, row.dataset.lineKey);
        });
        action.appendChild(btn);
      }
      row.appendChild(action);
      view.appendChild(row);
      // restore existing comment if any
      const existing = loadInlineComment(prKey, file.path, row.dataset.lineKey);
      if (existing) renderExistingCommentBelow(row, prKey, file.path, row.dataset.lineKey, existing);
      // inline annotations anchored to this new-file line number
      if (ln.newLn != null && byLine[ln.newLn]) {
        byLine[ln.newLn].forEach(a => {
          const glossRow = el("div", { class: "diff-row gloss-row" });
          glossRow.appendChild(el("div", { class: "diff-ln" }));
          glossRow.appendChild(el("div", { class: "diff-rn" }));
          glossRow.appendChild(el("div", { class: "diff-marker" }));
          const content = el("div", { class: "diff-content" });
          content.appendChild(renderGloss(a));
          glossRow.appendChild(content);
          glossRow.appendChild(el("div", { class: "diff-action" }));
          view.appendChild(glossRow);
        });
      }
    }
  }
  return view;
}

// ===== inline comment storage =====
function inlineKey(prKey, path, lineKey) { return `${STORAGE_PREFIX}:inline:${prKey}:${path}:${lineKey}`; }
function loadInlineComment(prKey, path, lineKey) { return localStorage.getItem(inlineKey(prKey, path, lineKey)); }
function saveInlineComment(prKey, path, lineKey, text) {
  if (text && text.trim()) localStorage.setItem(inlineKey(prKey, path, lineKey), text.trim());
  else localStorage.removeItem(inlineKey(prKey, path, lineKey));
}
function deleteInlineComment(prKey, path, lineKey) { localStorage.removeItem(inlineKey(prKey, path, lineKey)); }

// thread management: append after diff-row
function openInlineCommentEditor(row, prKey, path, lineKey, prefill) {
  // remove any existing thread/editor immediately following this row first
  let next = row.nextElementSibling;
  if (next && next.classList && next.classList.contains("comment-thread")) next.remove();
  const thread = el("div", { class: "comment-thread" });
  const ta = el("textarea", { class: "comment-textarea", placeholder: "Inline note for this line…" });
  if (prefill) ta.value = prefill;
  const actions = el("div", { class: "comment-form-actions" });
  const cancel = el("button", { class: "btn btn-ghost", type: "button" }, "Cancel");
  const save = el("button", { class: "btn btn-primary", type: "button" }, "Save");
  cancel.addEventListener("click", () => {
    thread.remove();
    const existing = loadInlineComment(prKey, path, lineKey);
    if (existing) renderExistingCommentBelow(row, prKey, path, lineKey, existing);
    refreshFileCommentCounts();
  });
  save.addEventListener("click", () => {
    saveInlineComment(prKey, path, lineKey, ta.value);
    thread.remove();
    const existing = loadInlineComment(prKey, path, lineKey);
    if (existing) renderExistingCommentBelow(row, prKey, path, lineKey, existing);
    refreshFileCommentCounts();
    showToast("Saved.");
  });
  actions.append(cancel, save);
  thread.append(ta, actions);
  row.parentNode.insertBefore(thread, row.nextElementSibling);
  ta.addEventListener("keydown", (e) => {
    if (e.key === "Escape") { e.preventDefault(); cancel.click(); }
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") { e.preventDefault(); save.click(); }
  });
  setTimeout(() => ta.focus(), 0);
}
function renderExistingCommentBelow(row, prKey, path, lineKey, text) {
  let next = row.nextElementSibling;
  if (next && next.classList && next.classList.contains("comment-thread")) next.remove();
  const thread = el("div", { class: "comment-thread" });
  const card = el("div", { class: "comment-existing" }, text);
  const actions = el("div", { class: "comment-actions" });
  const editBtn = el("button", { type: "button" }, "Edit");
  const delBtn = el("button", { type: "button" }, "Delete");
  editBtn.addEventListener("click", () => {
    thread.remove();
    openInlineCommentEditor(row, prKey, path, lineKey, text);
  });
  delBtn.addEventListener("click", () => {
    if (confirm("Delete this comment?")) {
      deleteInlineComment(prKey, path, lineKey);
      thread.remove();
      refreshFileCommentCounts();
    }
  });
  actions.append(editBtn, delBtn);
  thread.append(card, actions);
  row.parentNode.insertBefore(thread, row.nextElementSibling);
}

// counts per file
function refreshFileCommentCounts() {
  $$(".file-row").forEach(fr => {
    const prKey = fr.dataset.sha;
    const path = fr.dataset.path;
    let count = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith(`${STORAGE_PREFIX}:inline:${prKey}:${path}:`)) count++;
    }
    const cmtEl = $(".cmt", fr);
    if (cmtEl) {
      cmtEl.textContent = count > 0 ? `· ${count} 💬` : "";
    }
  });
}

// ===== page-level comments =====
function pageCommentKey(pageKey) { return `${STORAGE_PREFIX}:page:${pageKey}`; }
function loadPageComment(pageKey) { return localStorage.getItem(pageCommentKey(pageKey)) || ""; }
function savePageComment(pageKey, txt) {
  if (txt && txt.trim()) localStorage.setItem(pageCommentKey(pageKey), txt.trim());
  else localStorage.removeItem(pageCommentKey(pageKey));
}

// ===== decisions =====
function decisionKey(prKey) { return `${STORAGE_PREFIX}:decision:${prKey}`; }
function loadDecision(prKey) { return localStorage.getItem(decisionKey(prKey)); }
function saveDecision(prKey, decision) {
  if (decision) localStorage.setItem(decisionKey(prKey), decision);
  else localStorage.removeItem(decisionKey(prKey));
  refreshTriageList();
  refreshDots();
  refreshProgressReadout();
